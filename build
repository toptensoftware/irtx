#!/bin/bash

set -e

## Setup for build
#arduino-cli core update-index --additional-urls https://raw.githubusercontent.com/espressif/arduino-esp32/gh-pages/package_esp32_index.json
#arduino-cli core install esp32:esp32 --additional-urls https://raw.githubusercontent.com/espressif/arduino-esp32/gh-pages/package_esp32_index.json
#arduino-cli lib install "Adafruit NeoPixel"
#arduino-cli lib install "NimBLE-Arduino"

## Check board fqbn
#arduino-cli board listall | grep -i "c3_zero"

## Find Port
#arduino-cli board list

DO_BUILD=false
DO_FLASH=false
DO_CLEAN=false
DO_VERBOSE=false
BOARD=
PORT=

while [[ $# -gt 0 ]]; do
  case "$1" in
    --build) DO_BUILD=true ;;
    --flash) DO_FLASH=true ;;
    --clean) DO_CLEAN=true ;;
    --verbose) DO_VERBOSE=true ;;
    c3|c6)   BOARD=$1 ;;
    *)       PORT=$1 ;;
  esac
  shift
done

if [ -z "$BOARD" ]; then echo "Usage: $0 [--build] [--flash] <c3|c6> [<port>]"; exit 1; fi

# If neither flag given, do both
if ! $DO_BUILD && ! $DO_FLASH; then DO_BUILD=true; DO_FLASH=true; fi

# Work out board fqbn
case "$BOARD" in
  c3) FQBN=esp32:esp32:waveshare_esp32_c3_zero:PartitionScheme=huge_app ;;
  c6) FQBN=esp32:esp32:esp32c6:CDCOnBoot=cdc,PartitionScheme=huge_app ;;
esac

# Setup output directory
OUTPUT_DIR=./out/$BOARD
mkdir -p $OUTPUT_DIR

# Build
if $DO_BUILD; then

  # Build web ui
  (cd ./webui && npm install && npm run build)

  # Pack web ui into C++ source file
  node pack-web.js

  # Build firmware
  CLEAN_FLAG=""
  $DO_CLEAN && CLEAN_FLAG="--clean"
  VERBOSE_FLAG=""
  $DO_VERBOSE && VERBOSE_FLAG="--verbose"
  arduino-cli compile --fqbn $FQBN --build-path $OUTPUT_DIR $CLEAN_FLAG $VERBOSE_FLAG ./firmware
fi

# Flash
if $DO_FLASH; then
  if [ -z "$PORT" ]; then echo "Error: port required for flash"; exit 1; fi
  arduino-cli upload --fqbn $FQBN --build-path $OUTPUT_DIR --port $PORT ./firmware
fi


